# Telegram token from @BotFather
BOT_TOKEN=

# Channel/supergroup id, usually starts with -100
TELEGRAM_CHANNEL_ID=

# 16-64 random letters, numbers, _ or -
TELEGRAM_WEBHOOK_SECRET=

# A separate long random value used by the dashboard buttons
ADMIN_KEY=

# Render URL after deploy, for example https://telegram-alert.onrender.com
PUBLIC_URL=

# Optional: send a Telegram message to this chat for every new subscriber
ADMIN_CHAT_ID=

# channel = channel membership events, bot = first /start in the bot
SUBSCRIBER_SOURCE=channel

# Required for durable state on Render. Leave empty for the local D1 database.
DATABASE_URL=
